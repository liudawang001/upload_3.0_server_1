<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mls.upload.client.controller.MainController"
            prefHeight="700.0" prefWidth="900.0" styleClass="main-container">
   
   <!-- 顶部标题栏 -->
   <top>
      <VBox styleClass="header-container">
         <HBox alignment="CENTER" prefHeight="70.0" styleClass="title-bar">
            <Label text="木林森图片上传系统" styleClass="title-label">
               <font>
                  <Font name="Microsoft YaHei Bold" size="34.0" />
               </font>
            </Label>
         </HBox>
         <Separator />
      </VBox>
   </top>
   
   <!-- 主要内容区域 -->
   <center>
      <HBox spacing="10.0" styleClass="content-container">
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         
         <!-- 左侧操作区域 - 添加滚动支持 -->
         <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" 
                     pannable="false" styleClass="left-scroll-pane">
            <VBox prefWidth="350.0" spacing="15.0" styleClass="left-panel">
            <padding>
               <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
            </padding>
            
            <!-- 步骤1: 用户登录 -->
            <VBox spacing="10.0" styleClass="step-container">
               <Label text="步骤1: 用户登录" styleClass="step-title">
                  <font>
                     <Font name="Microsoft YaHei Bold" size="14.0" />
                  </font>
               </Label>
               <GridPane hgap="10.0" vgap="8.0">
                  <columnConstraints>
                     <ColumnConstraints hgrow="NEVER" minWidth="60.0" prefWidth="60.0" />
                     <ColumnConstraints hgrow="ALWAYS" />
                     <ColumnConstraints hgrow="NEVER" minWidth="80.0" prefWidth="80.0" />
                  </columnConstraints>
                  <rowConstraints>
                     <RowConstraints />
                     <RowConstraints />
                     <RowConstraints />
                     <RowConstraints />
                  </rowConstraints>
                  
                  <Label text="用户名:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                  <TextField fx:id="usernameField" promptText="请输入用户名" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                  
                  <Label text="密码:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                  <PasswordField fx:id="passwordField" promptText="请输入密码" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  
                  <CheckBox fx:id="rememberPasswordCheckBox" text="记住密码"
                           GridPane.columnIndex="1" GridPane.rowIndex="2" />

                  <Button fx:id="loginButton" onAction="#handleLogin" text="登录"
                          GridPane.columnIndex="2" GridPane.rowIndex="0" GridPane.rowSpan="2"
                          styleClass="primary-button" prefWidth="70.0" prefHeight="50.0" />

                  <Label fx:id="loginStatusLabel" text="未登录" styleClass="status-label"
                         GridPane.columnIndex="0" GridPane.columnSpan="3" GridPane.rowIndex="3" />
               </GridPane>
            </VBox>
            
            <!-- 步骤2: 选择图片类型 -->
            <VBox spacing="10.0" styleClass="step-container">
               <Label text="步骤2: 选择图片类型" styleClass="step-title">
                  <font>
                     <Font name="Microsoft YaHei Bold" size="14.0" />
                  </font>
               </Label>
               <HBox spacing="20.0" alignment="CENTER_LEFT">
                  <RadioButton fx:id="flowerTypeRadio" text="花型图" selected="true">
                     <toggleGroup>
                        <ToggleGroup fx:id="imageTypeGroup" />
                     </toggleGroup>
                  </RadioButton>
                  <RadioButton fx:id="colorTypeRadio" text="配色图" toggleGroup="$imageTypeGroup" />
               </HBox>
            </VBox>
            
            <!-- 步骤3: 上传Excel表格 -->
            <VBox spacing="10.0" styleClass="step-container">
               <Label text="步骤3: 上传Excel表格" styleClass="step-title">
                  <font>
                     <Font name="Microsoft YaHei Bold" size="14.0" />
                  </font>
               </Label>
               <VBox spacing="8.0">
                  <TextField fx:id="excelPathField" promptText="请选择Excel文件" editable="false" />
                  <HBox spacing="10.0" alignment="CENTER_LEFT">
                     <Button fx:id="selectExcelButton" onAction="#handleSelectExcel" text="选择文件" styleClass="secondary-button" prefWidth="120.0" />
                     <Button fx:id="uploadExcelButton" onAction="#handleUploadExcel" text="上传解析" styleClass="primary-button" disable="true" prefWidth="120.0" />
                  </HBox>
               </VBox>
               <Label fx:id="excelStatusLabel" text="未选择文件" styleClass="status-label" />
            </VBox>
            
            <!-- 步骤4: 选择图片文件夹 -->
            <VBox spacing="10.0" styleClass="step-container">
               <Label text="步骤4: 选择图片文件夹" styleClass="step-title">
                  <font>
                     <Font name="Microsoft YaHei Bold" size="14.0" />
                  </font>
               </Label>
               <VBox spacing="8.0">
                  <TextField fx:id="folderPathField" promptText="请选择图片文件夹" editable="false" />
                  <HBox spacing="10.0" alignment="CENTER_LEFT">
                     <Button fx:id="selectFolderButton" onAction="#handleSelectFolder" text="选择文件夹" styleClass="secondary-button" prefWidth="120.0" />
                     <Button fx:id="scanFolderButton" onAction="#handleScanFolder" text="扫描图片" styleClass="primary-button" disable="true" prefWidth="120.0" />
                  </HBox>
               </VBox>
               <Label fx:id="folderStatusLabel" text="未选择文件夹" styleClass="status-label" />
            </VBox>
            
            <!-- 步骤5: 开始上传 -->
            <VBox spacing="10.0" styleClass="step-container">
               <Label text="步骤5: 开始上传" styleClass="step-title">
                  <font>
                     <Font name="Microsoft YaHei Bold" size="14.0" />
                  </font>
               </Label>
               <HBox spacing="10.0" alignment="CENTER_LEFT">
                  <Button fx:id="startUploadButton" onAction="#handleStartUpload" text="开始上传"
                          styleClass="success-button" prefWidth="100.0" prefHeight="35.0" disable="true" />
                  <Button fx:id="pauseUploadButton" onAction="#handlePauseUpload" text="暂停上传"
                          styleClass="warning-button" disable="true" />
                  <Button fx:id="stopUploadButton" onAction="#handleStopUpload" text="停止上传"
                          styleClass="danger-button" disable="true" />
               </HBox>
               <ProgressBar fx:id="uploadProgressBar" prefWidth="300.0" progress="0.0" />
               <Label fx:id="uploadStatusLabel" text="准备就绪" styleClass="status-label" />
            </VBox>

            <!-- 导出功能区域 -->
            <VBox spacing="10.0" styleClass="step-container">
               <Label text="导出功能" styleClass="step-title">
                  <font>
                     <Font name="Microsoft YaHei Bold" size="14.0" />
                  </font>
               </Label>
               <Button fx:id="exportFailedButton" onAction="#handleExportFailedRecords" text="导出失败表格"
                       styleClass="secondary-button" prefWidth="150.0" disable="true" />
               <Button fx:id="exportUnuploadedButton" onAction="#handleExportUnuploadedRecords" text="导出未上传表格"
                       styleClass="secondary-button" prefWidth="150.0" disable="true" />
               <Button fx:id="exportMatchedImagesButton" onAction="#handleExportMatchedImages" text="导出匹配图片"
                       styleClass="secondary-button" prefWidth="150.0" disable="true" />
            </VBox>

            </VBox>
         </ScrollPane>
         
         <!-- 右侧日志显示区域 -->
         <VBox HBox.hgrow="ALWAYS" spacing="10.0" styleClass="right-panel">
            <padding>
               <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
            </padding>
            
            <!-- 日志标题和控制按钮 -->
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <Label text="上传日志" styleClass="panel-title">
                  <font>
                     <Font name="Microsoft YaHei Bold" size="16.0" />
                  </font>
               </Label>
               <Region HBox.hgrow="ALWAYS" />
               <Button fx:id="selectAllButton" onAction="#handleSelectAll" text="全选" styleClass="secondary-button" />
               <Button fx:id="clearLogButton" onAction="#handleClearLog" text="清空日志" styleClass="secondary-button" />
               <Button fx:id="exportLogButton" onAction="#handleExportLog" text="导出日志" styleClass="secondary-button" />
            </HBox>
            
            <!-- 日志表格 -->
            <TableView fx:id="logTableView" VBox.vgrow="ALWAYS" styleClass="log-table">
               <columns>
                  <TableColumn fx:id="selectColumn" text="选择" prefWidth="50.0" />
                  <TableColumn fx:id="indexColumn" text="序号" prefWidth="50.0" />
                  <TableColumn fx:id="productCodeColumn" text="商品编号" prefWidth="120.0" />
                  <TableColumn fx:id="filenameColumn" text="图片名称" prefWidth="150.0" />
                  <TableColumn fx:id="matchStatusColumn" text="比对状态" prefWidth="80.0" />
                  <TableColumn fx:id="uploadStatusColumn" text="上传状态" prefWidth="80.0" />
                  <TableColumn fx:id="progressColumn" text="进度" prefWidth="80.0" />
                  <TableColumn fx:id="messageColumn" text="备注信息" prefWidth="150.0" />
                  <TableColumn fx:id="timeColumn" text="时间" prefWidth="120.0" />
               </columns>
            </TableView>
            
         </VBox>
         
      </HBox>
   </center>
   
   <!-- 底部状态栏 -->
   <bottom>
      <VBox styleClass="footer-container">
         <Separator />
         <HBox alignment="CENTER_LEFT" prefHeight="30.0" spacing="20.0" styleClass="status-bar">
            <padding>
               <Insets left="10.0" right="10.0" />
            </padding>
            <Label fx:id="connectionStatusLabel" text="服务器连接: 未连接" styleClass="connection-status" />
            <Separator orientation="VERTICAL" />
            <Label fx:id="totalCountLabel" text="总数: 0" />
            <Label fx:id="successCountLabel" text="成功: 0" styleClass="success-text" />
            <Label fx:id="failedCountLabel" text="失败: 0" styleClass="error-text" />
            <Label fx:id="scanResultLabel" text="" styleClass="scan-result" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="currentTimeLabel" text="2025-09-11 11:45:00" styleClass="time-label" />
         </HBox>
      </VBox>
   </bottom>
   
</BorderPane>

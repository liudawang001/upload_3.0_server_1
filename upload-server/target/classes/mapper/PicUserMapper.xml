<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mls.upload.server.mapper.PicUserMapper">

    <!-- 用户信息结果映射 -->
    <resultMap id="PicUserResultMap" type="com.mls.upload.server.entity.PicUser">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="password" column="password"/>
        <result property="nickname" column="nickname"/>
        <result property="createTime" column="create_time"/>
        <result property="updataTime" column="updata_time"/>
    </resultMap>

    <!-- 基础查询字段 -->
    <sql id="Base_Column_List">
        id, username, password, nickname, create_time, updata_time
    </sql>

    <!-- 复杂查询：根据条件查询用户列表 -->
    <select id="findByCondition" resultMap="PicUserResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM pic_user
        <where>
            <if test="username != null and username != ''">
                AND username LIKE CONCAT('%', #{username}, '%')
            </if>
            <if test="nickname != null and nickname != ''">
                AND nickname LIKE CONCAT('%', #{nickname}, '%')
            </if>
            <if test="startTime != null">
                AND create_time >= #{startTime}
            </if>
            <if test="endTime != null">
                AND create_time &lt;= #{endTime}
            </if>
        </where>
        ORDER BY create_time DESC
        <if test="limit != null and limit > 0">
            LIMIT #{limit}
        </if>
    </select>

    <!-- 批量插入用户 -->
    <insert id="batchInsert" parameterType="java.util.List">
        INSERT INTO pic_user (username, password, nickname, create_time, updata_time)
        VALUES
        <foreach collection="list" item="user" separator=",">
            (#{user.username}, #{user.password}, #{user.nickname}, #{user.createTime}, #{user.updataTime})
        </foreach>
    </insert>

    <!-- 批量更新用户状态 -->
    <update id="batchUpdateStatus" parameterType="java.util.Map">
        UPDATE pic_user
        SET updata_time = NOW()
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>

    <!-- 根据用户名模糊查询 -->
    <select id="findByUsernameLike" resultMap="PicUserResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM pic_user
        WHERE username LIKE CONCAT('%', #{username}, '%')
        ORDER BY create_time DESC
    </select>

    <!-- 统计指定时间范围内的用户数量 -->
    <select id="countByTimeRange" resultType="int">
        SELECT COUNT(*)
        FROM pic_user
        WHERE create_time BETWEEN #{startTime} AND #{endTime}
    </select>

</mapper>
